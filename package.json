{
  "name": "aipoker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@aipoker/server --filter=@aipoker/web",
    "dev:all": "pnpm dev",
    "dev:web": "pnpm --filter @aipoker/web dev",
    "dev:server": "pnpm --filter @aipoker/server dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:local": "node --experimental-strip-types --test packages/*/src/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  }
}
