{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Next.js 15 推荐设置（覆盖 base.json 的 NodeNext）
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // 路径别名
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@aipoker/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@aipoker/game-engine": [
        "../../packages/game-engine/src/index.ts"
      ],
      "@aipoker/bot-engine": [
        "../../packages/bot-engine/src/index.ts"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
